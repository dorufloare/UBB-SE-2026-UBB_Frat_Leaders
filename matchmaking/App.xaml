<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="matchmaking.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:matchmaking"
    xmlns:converters="using:matchmaking.Converters"
    xmlns:session="using:matchmaking.Domain.Session">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:ChatNameConverter x:Key="ChatNameConverter" />
            <converters:ChatPartyNameConverter x:Key="ChatPartyNameConverter" />
            <converters:ObjectToVisibilityConverter x:Key="ObjectToVisibilityConverter" />
            <converters:IsOtherPartyMessageConverter x:Key="IsOtherPartyMessageConverter" />
            <converters:IsCurrentUserMessageConverter x:Key="IsCurrentUserMessageConverter" />
            <converters:MessageTextVisibilityConverter x:Key="MessageTextVisibilityConverter" />
            <converters:MessageAttachmentVisibilityConverter x:Key="MessageAttachmentVisibilityConverter" />
            <converters:MessageFileAttachmentVisibilityConverter x:Key="MessageFileAttachmentVisibilityConverter" />
            <converters:MessageImageVisibilityConverter x:Key="MessageImageVisibilityConverter" />
            <converters:MessageImageSourceConverter x:Key="MessageImageSourceConverter" />
            <converters:ReadReceiptConverter x:Key="ReadReceiptConverter" />
            <converters:MessageContentDisplayConverter x:Key="MessageContentDisplayConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <converters:ChatAvatarCornerRadiusConverter x:Key="ChatAvatarCornerRadiusConverter" />
            <converters:ChatAvatarBgConverter x:Key="ChatAvatarBgConverter" />
            <converters:ChatAvatarFgConverter x:Key="ChatAvatarFgConverter" />
            <converters:ChatInitialsConverter x:Key="ChatInitialsConverter" />
            <converters:ChatSubtitleConverter x:Key="ChatSubtitleConverter" />
            <session:SessionContext x:Key="SessionContext" />

            <x:Double x:Key="SpacingXS">8</x:Double>
            <x:Double x:Key="SpacingS">12</x:Double>
            <x:Double x:Key="SpacingM">16</x:Double>
            <x:Double x:Key="SpacingL">24</x:Double>
            <x:Double x:Key="SpacingXL">32</x:Double>

            <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#FFF5F7FB" />
            <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF111827" />
            <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE8E4DC" />

            <!-- Existing brushes -->
            <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#FF2563EB" />
            <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#FF9CA3AF" />
            <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#FF111827" />

            <!-- New brushes to fix ChatPageView missing resource errors -->
            <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#FFE5E7EB" />
            <SolidColorBrush x:Key="SurfaceWeakBrush" Color="#FFF9FAFB" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF111827" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7280" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF2563EB" />
            <SolidColorBrush x:Key="DividerBrush" Color="#FFD1D5DB" />

            <Style x:Key="HeaderNavButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="Margin" Value="6,0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource HeaderForegroundBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="Background" Value="{StaticResource PrimaryButtonBackgroundBrush}" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryButtonForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBackgroundBrush}" />
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource SecondaryButtonForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
