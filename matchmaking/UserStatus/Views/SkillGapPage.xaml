<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.UserStatus.Views.SkillGapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F0F2F5">

    <Page.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="56,*">

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="Black" BorderThickness="0,0,0,2">
            <Grid Padding="24,0" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Source="/Assets/div.nav-logo-mark.png" Width="28" Height="28" VerticalAlignment="Center"/>
                    <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="Tinder" Foreground="Black"/>
                        <Run Text="Jobs" Foreground="#888888"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="28" VerticalAlignment="Center">
                    <Button Content="Recommendations" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="My Status" Style="{StaticResource NavButtonStyle}"
                            Click="BackToStatus_Click"/>
                    <Button Content="Chat" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
                <PersonPicture Grid.Column="2" Width="34" Height="34" Initials="AJ" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Padding="40,28">
            <Grid RowDefinitions="Auto,*">

                <!-- Header: Back + Title + Refresh -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Button x:Name="BackButton" Content="← Back to My Status"
                            VerticalAlignment="Center" Click="BackToStatus_Click"/>
                    <TextBlock Text="Skill Gap Analysis" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="RefreshButton" Content="Refresh"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="RefreshButton_Click"/>
                </Grid>

                <!-- Loading -->
                <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="True"
                              Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Content -->
                <ScrollViewer x:Name="ContentScrollViewer" Grid.Row="1" Visibility="Collapsed">
                    <StackPanel Spacing="24" MaxWidth="720" Padding="0,0,0,20">

                        <!-- Summary stat cards (shown when there are gaps) -->
                        <StackPanel x:Name="SummaryStatsPanel"
                                    Orientation="Horizontal" Spacing="16"
                                    Visibility="Collapsed"/>

                        <!-- Simple message (no rejections / no gaps / error) -->
                        <Border x:Name="SummaryMessageBorder"
                                Background="White" CornerRadius="10"
                                Padding="28" Visibility="Collapsed">
                            <TextBlock x:Name="SummaryText" FontSize="14"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Skills to Improve -->
                        <StackPanel x:Name="UnderscoredSection" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="Skills to Improve" FontSize="17" FontWeight="Bold"/>
                            <StackPanel x:Name="UnderscoredPanel" Spacing="10"/>
                        </StackPanel>

                        <!-- Missing Skills -->
                        <StackPanel x:Name="MissingSection" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="Missing Skills" FontSize="17" FontWeight="Bold"/>
                            <StackPanel x:Name="MissingPanel" Spacing="10"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</Page>
