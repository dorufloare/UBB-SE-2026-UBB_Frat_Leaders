<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.Pages.CompanyStatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:matchmaking.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#EDECE6">

    <Page.Resources>
        <converters:MatchStatusDisplayConverter x:Key="MatchStatusDisplayConverter"/>
    </Page.Resources>

    <Grid>

        <Grid x:Name="ApplicantListPanel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,36,48,48" Spacing="0">

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6" VerticalAlignment="Bottom">
                            <TextBlock Text="Applicant List"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock Text="{Binding PageMessage}"
                                       FontSize="13"
                                       Foreground="#1D4ED8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    VerticalAlignment="Bottom">
                            <ProgressRing IsActive="{Binding IsLoading}"
                                          Width="20"
                                          Height="20"
                                          VerticalAlignment="Center"/>
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#9CA3AF"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#111827"/>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ItemsRepeater ItemsSource="{Binding Applications}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="300"
                                               MinColumnSpacing="16"
                                               MinRowSpacing="16"
                                               Orientation="Horizontal"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18">
                                    <StackPanel Spacing="0">

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding User.Name}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1"
                                                    Background="{Binding Match.Status, Converter={StaticResource MatchStatusDisplayConverter}, ConverterParameter=Background}"
                                                    CornerRadius="20"
                                                    Padding="9,3"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Match.Status, Converter={StaticResource MatchStatusDisplayConverter}, ConverterParameter=Label}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Match.Status, Converter={StaticResource MatchStatusDisplayConverter}, ConverterParameter=Foreground}"/>
                                            </Border>
                                        </Grid>

                                        <Border Height="1"
                                                Background="#F3F4F6"
                                                Margin="0,10,0,12"/>

                                        <Button Content="Review ->"
                                                Tag="{Binding Match.MatchId}"
                                                Click="OnReviewApplicantClick"
                                                Style="{StaticResource PrimaryActionButtonStyle}"
                                                HorizontalAlignment="Left">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2563EB"/>
                                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#2563EB"/>
                                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                            </Button.Resources>
                                        </Button>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="EvaluationPanel" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,36,48,56"
                            Spacing="14"
                            MaxWidth="720"
                            HorizontalAlignment="Left">

                    <TextBlock Text="Applicant Evaluation"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,10"/>

                    <Border Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22">
                        <StackPanel Spacing="14">

                            <TextBlock Text="PROFILE"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#9CA3AF"
                                       CharacterSpacing="100"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding SelectedApplicant.User.Name}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock Text="{Binding SelectedApplicant.Job.JobTitle}"
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Height="1" Background="#F3F4F6"/>

                            <Grid ColumnSpacing="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="LOCATION"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding SelectedApplicant.User.Location}"
                                               FontSize="13"
                                               Foreground="#374151"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="EDUCATION"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding SelectedApplicant.User.Education}"
                                               FontSize="13"
                                               Foreground="#374151"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock Text="EXPERIENCE"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock FontSize="13"
                                               Foreground="#374151">
                                        <Run Text="{Binding SelectedApplicant.User.YearsOfExperience}"/>
                                        <Run Text=" years"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="3">
                                <TextBlock Text="RESUME"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#9CA3AF"
                                           CharacterSpacing="80"/>
                                <TextBlock Text="{Binding SelectedApplicant.User.Resume}"
                                           FontSize="13"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22">
                        <StackPanel Spacing="14">

                            <TextBlock Text="CONTACT"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#9CA3AF"
                                       CharacterSpacing="100"/>

                            <Grid ColumnSpacing="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="EMAIL"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding ContactEmailDisplay}"
                                                FontSize="13"
                                                Foreground="#065F46"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="PHONE"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding ContactPhoneDisplay}"
                                                FontSize="13"
                                                Foreground="#065F46"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22">
                        <StackPanel Spacing="16">

                            <TextBlock Text="TECHNICAL TEST RESULTS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#9CA3AF"
                                       CharacterSpacing="100"/>

                            <Grid ColumnSpacing="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="CANDIDATE ID"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding LastTestResult.ExternalUserId}"
                                               FontSize="13"
                                               Foreground="#374151"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="TEST ID"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding LastTestResult.Test.TestId}"
                                               FontSize="13"
                                               Foreground="#374151"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock Text="SCORE"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               CharacterSpacing="80"/>
                                    <TextBlock Text="{Binding LastTestResult.Attempt.Score}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#F3F4F6"/>

                            <TextBlock Text="Written Answers"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"/>

                            <ItemsControl ItemsSource="{Binding LastTestResult.Questions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FAFAFA"
                                                BorderBrush="#F3F4F6"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="14"
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="{Binding QuestionText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#374151"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding QuestionAnswer}"
                                                           FontSize="13"
                                                           Foreground="#6B7280"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22">
                        <StackPanel Spacing="16">

                            <TextBlock Text="DECISION"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#9CA3AF"
                                       CharacterSpacing="100"/>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Status"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"/>
                                <Border x:Name="DecisionFieldBorder"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4">
                                    <ComboBox ItemsSource="{Binding DecisionOptions}"
                                              SelectedItem="{Binding SelectedDecision, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              Foreground="#111827"
                                              BorderThickness="0"
                                              Background="Transparent">
                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="ComboBoxForeground" Color="#111827"/>
                                            <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#111827"/>
                                            <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="#111827"/>
                                            <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#111827"/>
                                            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#111827"/>
                                            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#DBEAFE"/>
                                        </ComboBox.Resources>
                                    </ComboBox>
                                </Border>
                                <TextBlock Text="{Binding ValidationErrorDecision}"
                                           FontSize="12"
                                           Foreground="#B91C1C"/>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Feedback"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"/>
                                <Border x:Name="FeedbackFieldBorder"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4">
                                    <TextBox Text="{Binding FeedbackMessage, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             MinHeight="100"
                                             PlaceholderText="Write your feedback for the applicant..."
                                             TextWrapping="Wrap"
                                             BorderThickness="0"
                                             Background="Transparent"/>
                                </Border>
                                <TextBlock Text="{Binding ValidationErrorFeedback}"
                                           FontSize="12"
                                           Foreground="#B91C1C"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Submit Decision"
                                Click="OnSubmitDecisionClickAsync"
                                Style="{StaticResource PrimaryActionButtonStyle}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2563EB"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#2563EB"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                            </Button.Resources>
                        </Button>
                        <Button Content="Cancel"
                                Click="OnCancelEvaluationClickAsync"
                                Style="{StaticResource SecondaryActionButtonStyle}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#9CA3AF"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#111827"/>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
