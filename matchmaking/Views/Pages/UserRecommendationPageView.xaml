<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.Pages.UserRecommendationPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:matchmaking.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:matchmaking.ViewModels"
    x:DataType="local:UserRecommendationPageView"
    xmlns:local="using:matchmaking.Views.Pages"
    mc:Ignorable="d"
    Background="{StaticResource ShellBackgroundBrush}">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid>
        <SplitView x:Name="RootSplit"
                   PaneBackground="{StaticResource CardBackgroundBrush}"
                   OpenPaneLength="360"
                   CompactPaneLength="0"
                   DisplayMode="Overlay"
                   IsPaneOpen="{x:Bind ViewModel.IsFilterOpen, Mode=TwoWay}">
            <SplitView.Pane>
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Filters"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Employment type"
                                   FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DraftEmploymentSelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:FilterCheckItem">
                                    <CheckBox Content="{x:Bind Label}"
                                              IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Experience level"
                                   FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DraftExperienceSelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:FilterCheckItem">
                                    <CheckBox Content="{x:Bind Label}"
                                              IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox Header="Location contains"
                                 Text="{x:Bind ViewModel.DraftLocation, Mode=TwoWay}"
                                 PlaceholderText="City or region" />
                        <TextBlock Text="Required skills (any)"
                                   FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DraftSkillSelections}"
                                      MaxHeight="200">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:SkillFilterItem">
                                    <CheckBox Content="{x:Bind Name}"
                                              IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Apply"
                                    Command="{x:Bind ViewModel.ApplyFiltersCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Reset"
                                    Command="{x:Bind ViewModel.ResetFiltersCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </SplitView.Pane>
            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Recommendations"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Content="Refresh"
                                Command="{x:Bind ViewModel.RefreshCommand}" />
                        <Button Content="Filters"
                                Command="{x:Bind ViewModel.OpenFiltersCommand}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <ProgressRing Width="48"
                                  Height="48"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12"
                                MaxWidth="420"
                                Visibility="{x:Bind ViewModel.ShowEmptyDeck, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="No more jobs match your filters right now."
                                   TextWrapping="WrapWholeWords"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <Button Content="Open filters"
                                Command="{x:Bind ViewModel.OpenFiltersCommand}"
                                HorizontalAlignment="Center" />
                        <Button Content="Refresh"
                                Command="{x:Bind ViewModel.RefreshCommand}"
                                HorizontalAlignment="Center" />
                    </StackPanel>

                    <Border Padding="24"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            MaxWidth="520"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.HasCard, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="8"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="&#xE7C3;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentJob.Company.CompanyName, Mode=OneWay}"
                                               FontWeight="SemiBold"
                                               FontSize="18" />
                                    <TextBlock Text="{x:Bind ViewModel.CurrentJob.JobTitleLine, Mode=OneWay}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.CurrentJob.LocationEmploymentLine, Mode=OneWay}" />
                            <TextBlock Text="Top skills"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentJob.TopSkillLabels, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Bind ViewModel.CurrentJob.DescriptionExcerpt, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentJob.MatchLineLabel, Mode=OneWay}" />
                            <Button Content="View full details"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.OpenDetailCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Vertical"
                            Spacing="12"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="24">
                        <Button Width="120"
                                Height="56"
                                Background="#FFB91C1C"
                                Foreground="White"
                                Content="Dismiss"
                                Command="{x:Bind ViewModel.DismissCommand}"
                                IsEnabled="{x:Bind ViewModel.HasCard, Mode=OneWay}" />
                        <Button Width="120"
                                Height="56"
                                Background="#FF15803D"
                                Foreground="White"
                                Content="Like"
                                Command="{x:Bind ViewModel.LikeCommand}"
                                IsEnabled="{x:Bind ViewModel.HasCard, Mode=OneWay}" />
                    </StackPanel>
                    <Button Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            Command="{x:Bind ViewModel.UndoCommand}"
                            IsEnabled="{x:Bind ViewModel.CanUndo, Mode=OneWay}"
                            ToolTipService.ToolTip="Undo last action">
                        <FontIcon Glyph="&#xE72B;"
                                  FontSize="20" />
                    </Button>
                </StackPanel>
            </Grid>
        </SplitView>

        <!-- Detail overlay -->
        <Grid Background="#99000000"
              Padding="24"
              Visibility="{x:Bind ViewModel.IsDetailOpen, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <Border MaxWidth="640"
                    MaxHeight="640"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="24"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.CurrentJob.Company.CompanyName, Mode=OneWay}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentJob.JobTitleLine, Mode=OneWay}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentJob.LocationEmploymentLine, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentJob.MatchLineLabel, Mode=OneWay}" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Description"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentJob.Job.JobDescription, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="Required skills"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentJob.AllSkillLabels, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="0,2,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Contact"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentJob.ContactLine, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Stretch"
                                Spacing="8">
                        <Button Content="Back"
                                Command="{x:Bind ViewModel.CloseDetailCommand}" />
                        <Button Content="Dismiss"
                                Command="{x:Bind ViewModel.DismissCommand}"
                                Background="#FFB91C1C"
                                Foreground="White" />
                        <Button Content="Like"
                                Command="{x:Bind ViewModel.LikeCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
