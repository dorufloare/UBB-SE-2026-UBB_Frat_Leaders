<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.Pages.JobPostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F0F2F5">

    <Grid Padding="24" RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
            <Button Content="← Back" Click="Back_Click" Foreground="#111827" />
            <TextBlock Grid.Column="1"
                       Text="Job Post"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <Border Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="10" Padding="18" MaxWidth="860">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock Text="{Binding Meta}" Foreground="#374151" />
                    <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#111827" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
