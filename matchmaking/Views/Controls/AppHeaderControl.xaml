<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="matchmaking.Views.Controls.AppHeaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="72"
          Padding="24,12"
          Background="{StaticResource HeaderBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8">
            <FontIcon Glyph="&#xE8A5;"
                      Foreground="{StaticResource HeaderForegroundBrush}"
                      FontSize="18" />
            <TextBlock Text="Matchmaking"
                       Foreground="{StaticResource HeaderForegroundBrush}"
                       FontSize="20"
                       FontWeight="SemiBold" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <Button Content="Recommendations"
                    Command="{Binding RecommendationsCommand}"
                    Style="{StaticResource HeaderNavButtonStyle}" />
            <Button Content="My Status"
                    Command="{Binding MyStatusCommand}"
                    Style="{StaticResource HeaderNavButtonStyle}" />
            <Button Content="Chat"
                    Command="{Binding ChatCommand}"
                    Style="{StaticResource HeaderNavButtonStyle}" />
        </StackPanel>

        <Grid Grid.Column="2"
              HorizontalAlignment="Right"
              VerticalAlignment="Center">
            <Ellipse Width="36"
                     Height="36"
                     Fill="#FF374151" />
            <TextBlock Text="U"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="SemiBold" />
        </Grid>
    </Grid>
</UserControl>